meta {
  name: Show details of a specific event report
  type: http
  seq: 2
}

get {
  url: {{protocol}}://{{delegatedURL}}/_synapse/admin/v1/event_reports/:report_id
  body: none
  auth: inherit
}

params:path {
  report_id: 12345
}

vars:post-response {
  roomId: res.body.room_id,
  eventId: res.body.event_id
}
